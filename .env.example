# A chave secreta usada para assinar os tokens (extremamente importante mudar isso ao ir para produção).
JWT_SECRET_KEY="change-this-secret-key-in-production"

# O algoritmo de criptografia do token.
JWT_ALGORITHM="HS256"

# O tempo de vida do token de login em minutos.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Quantos minutos de atraso o sistema tolera após o início da reserva antes de cancelar automaticamente por no-show.
NO_SHOW_GRACE_MINUTES=15

# Máximo de reservas ativas (pending ou approved) simultâneas permitidas.
USER_MAX_ACTIVE_RESERVATIONS=2

# Total de horas máximas que um usuário comum pode reservar por dia (UTC).
USER_MAX_HOURS_PER_DAY=4

# Duração máxima permitida para uma única reserva de um usuário comum (em horas).
USER_MAX_HOURS_PER_RESERVATION=2
